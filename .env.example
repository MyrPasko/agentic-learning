# Copy this file to .env and fill values locally.
# Never commit .env.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agentic-learning-week1
